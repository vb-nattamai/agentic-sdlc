# .env.example — copy to .env and fill in your values
# Never commit .env to version control.

# ── Required ──────────────────────────────────────────────────────────────────

# GitHub Models API is accessed via 'gh auth token'; no explicit token needed here.
# Run: gh auth login   (if not already authenticated)

# ── Optional — LLM model override ─────────────────────────────────────────────

# Model to use for all LLM calls (default: gpt-4o)
# Supported: any model available on https://models.inference.ai.azure.com
# PIPELINE_MODEL=gpt-4o

# ── Optional — 3rd-party integrations ─────────────────────────────────────────

# JIRA integration (used by api_call tool with service="jira")
# JIRA_URL=https://your-org.atlassian.net
# JIRA_TOKEN=your_jira_api_token

# Linear integration (used by api_call tool with service="linear")
# LINEAR_TOKEN=your_linear_api_key

# Slack integration (used by api_call tool with service="slack")
# SLACK_TOKEN=xoxb-your-slack-bot-token
